# Mantle Sepolia RPC endpoint (defaults to the public node if unset).
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz

# Deployer private key (0x-prefixed). NEVER commit a real key — this file is for
# .env.example only; put the real key in contracts/.env (gitignored).
# Leave empty to compile/test without a funded account.
# `PRIVATE_KEY` is also accepted as a fallback name.
DEPLOYER_PRIVATE_KEY=

# API key for contract verification on the Mantle Sepolia explorer.
# Any non-empty value works for the Blockscout-compatible verifier.
MANTLESCAN_API_KEY=
