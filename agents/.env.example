# Dead Ringer — agents service
# Copy to .env and fill in values. Never commit .env.

# HTTP + WebSocket port (klink owns 3000; web dev server is 3100)
PORT=3101

# Comma-separated CoinGecko asset IDs to poll
FEED_ASSETS=ethereum,bitcoin

# Price-feed polling interval in milliseconds
FEED_POLL_MS=3000

# Set to 'true' to persist every trade to agents/data/trades.json
PERSIST_TRADES=false

# DR-203 Cut #3 — set 'true' to drop the 4th bot (Paper Hands) → 3 bots
DISABLE_PAPER_HANDS=false

# DR-201 (pending credits) — when set, The Degen's heuristic brain can be
# swapped for an LLM call via Z.AI. Unset = deterministic heuristic (default).
# ZAI_API_KEY=
